# AI Configuration
# The router will attempt to use keys in this order: Gemini -> OpenAI -> Groq
GEMINI_API_KEYS=key1,key2,key3
OPENAI_API_KEYS=sk-proj-key1,sk-proj-key2
GROQ_API_KEYS=gsk_key1,gsk_key2

# Material Analysis LLM Priority (comma-separated: groq, gemini, openai)
# This controls the order for text-only material analysis (not image analysis)
# Example: MATERIAL_ANALYSIS_LLM_PRIORITY=groq,gemini,openai
MATERIAL_ANALYSIS_LLM_PRIORITY=groq,gemini,openai

# Image Analysis LLM Priority (comma-separated: gemini, openai, groq)
# This controls the order for image-based device identification
# Example: IMAGE_ANALYSIS_LLM_PRIORITY=gemini,openai,groq
IMAGE_ANALYSIS_LLM_PRIORITY=gemini,openai,groq

# Service Authentication
# Generate a secure random key: openssl rand -hex 32
API_KEY=your_service_api_key_here

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# File Upload Configuration
MAX_FILE_SIZE_MB=10

# Logging Configuration
LOG_LEVEL=INFO

# Request Configuration
REQUEST_TIMEOUT=30

# Rate Limiting Configuration
RATE_LIMIT=10/minute

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elocate
DB_USER=analyzer_readonly
DB_PASSWORD=your_database_password_here
DB_SSL_MODE=require
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=20
DB_CONNECTION_TIMEOUT=10
DB_QUERY_TIMEOUT=50

# Fuzzy Matching Thresholds (0.0 to 1.0)
CATEGORY_MATCH_THRESHOLD=0.80
BRAND_MATCH_THRESHOLD=0.80
MODEL_MATCH_THRESHOLD=0.75

# Cache Configuration
QUERY_CACHE_TTL=300
QUERY_CACHE_MAX_SIZE=1000

